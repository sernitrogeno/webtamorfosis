# =====================================================================
# Variables de entorno de Webtamorfosis
# Copia este archivo a ".env.local" y completa los valores reales.
# NUNCA subas ".env.local" al repositorio (ya está en .gitignore).
# En Vercel, añade estas mismas variables en Project → Settings → Environment Variables.
# =====================================================================

# URL pública del sitio (SEO, sitemap, datos estructurados)
NEXT_PUBLIC_SITE_URL=https://www.webtamorfosis.es

# --- Base de datos: Supabase (guarda las solicitudes del formulario) --------
# En Supabase: Project Settings → API.
#   SUPABASE_URL              = "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY = "service_role" (¡SECRETA! solo servidor, sin NEXT_PUBLIC)
# Si no las defines, el formulario funciona en modo simulado (no guarda).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email de aviso (opcional) ----------------------------------------------
# Para recibir un correo cada vez que llega una solicitud (Resend).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_TO_EMAIL=hola@webtamorfosis.es
# CONTACT_FROM_EMAIL=web@webtamorfosis.es

# --- Analítica (opcional, se activa tras el consentimiento de cookies) -------
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
